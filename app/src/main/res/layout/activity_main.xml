<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/input_container"
        android:name="com.example.lab2_bilyi_variant3.InputFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <View android:layout_width="match_parent" android:layout_height="2dp"
        android:background="@android:color/darker_gray" android:layout_marginVertical="8dp" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/output_container"
        android:name="com.example.lab2_bilyi_variant3.OutputFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>